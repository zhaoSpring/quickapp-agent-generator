<template>
  <div class="intro-wrapper">
    <image if="{{ agentInfo.icon }}" class="intro-avatar" src="{{ agentInfo.icon }}"></image>
    <div class="intro-content">
      <text if="{{ agentInfo.description || agentInfo.prologue }}" class="intro-text">{{
        agentInfo.description || agentInfo.prologue
      }}</text>
      <div
        if="{{ agentInfo.openingQuestions && agentInfo.openingQuestions.length }}"
        class="intro-questions"
      >
        <div
          class="intro-question-item"
          for="{{ agentInfo.openingQuestions.slice(0, 3) }}"
          onclick="useSuggestion($item)"
        >
          <image class="intro-star" src="/assets/images/icon-intro-star.svg"></image>
          <text class="intro-question">{{ $item }}</text>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
export default {
  props: {
    agentInfo: {
      type: Object,
      default: () => ({
        agentName: '',
        icon: '',
        description: '',
        userName: '',
        userCount: 0,
      }),
    },
  },
  useSuggestion(question) {
    this.$emit('suggestion', { question })
  },
}
</script>

