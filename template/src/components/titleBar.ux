<template>
  <div class="title-bar-wrapper">
    <div class="title-bar">
      <div class="btn" @click="handleLeftClick">
        <image class="back-icon" src="/assets/images/icon-back.svg"></image>
      </div>
      <div class="title-content" @click="handleTitleClick">
        <div class="title">
          <image
            if="{{ agentInfo.icon }}"
            class="title-icon"
            src="{{ agentInfo.icon }}"
          ></image>
          <text class="title-text ellipsis">{{ agentInfo.agentName || title }}</text>
        </div>
        <text if="{{ agentInfo.agentName }}" class="ai-hint ellipsis">内容由AI生成 仅供参考</text>
      </div>
      <div class="btn">
        <slot name="right"></slot>
      </div>
    </div>
  </div>
</template>

<script>
import router from '@system.router'
export default {
  props: {
    agentInfo: {
      type: Object,
      default: {},
    },
    title: {
      type: String,
      default: '',
    },
    customBack: {
      type: Boolean,
      default: false,
    },
  },

  handleLeftClick() {
    if (this.customBack) {
      this.$emit('leftclick')
    } else {
      router.back()
    }
  },
  
  handleTitleClick() {
    this.$emit('titleclick')
  },
}
</script>

<style lang="less">
.title-bar-wrapper {
  padding: 0 20px;
  width: 100%;
  flex-direction: column;
  background-color: #f7f7f7;
  padding-top: 35px;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 100;
  
  .title-bar {
    width: 100%;
    height: 62px;
    align-items: center;
    justify-content: space-between;

    .btn {
      align-items: center;
      justify-content: center;
      height: 100%;
      min-width: 40px;
    }
    
    .back-icon {
      width: 24px;
      height: 24px;
    }
    
    .title-content {
      flex-direction: column;
      align-items: center;
      justify-content: center;

      .title-icon {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        margin-right: 4px;
      }
      
      .title {
        align-items: center;
      }

      .title-text {
        font-size: 18px;
        font-weight: 800;
        color: #000000;
        max-width: 200px;
      }

      .ai-hint {
        font-size: 12px;
        font-weight: 400;
        color: rgba(0, 0, 0, 0.4);
        max-width: 200px;
        margin-top: 2px;
      }
    }
  }
}
</style>
