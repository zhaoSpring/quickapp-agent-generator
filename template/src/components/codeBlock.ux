<template>
  <div class="code-block-container">
    <div class="code-header">
      <text class="language-label">{{ language || 'plaintext' }}</text>
      <div class="copy-button" onclick="handleCopy">
        <text class="copy-text">复制</text>
      </div>
    </div>
    <richtext type="html" style="background-color: transparent">{{ highlightedCode }}</richtext>
  </div>
</template>

<script>
import clipboard from '@system.clipboard'
import prompt from '@system.prompt'
import hljs from 'highlight.js'

export default {
  props: {
    code: {
      type: String,
      default: '',
    },
    language: {
      type: String,
      default: '',
    },
  },
  
  computed: {
    highlightedCode() {
      if (!this.code) return ''

      let codeHtml = ''
      try {
        if (this.language && hljs.getLanguage(this.language)) {
          codeHtml = hljs.highlight(this.code, { language: this.language }).value
        } else {
          codeHtml = hljs.highlightAuto(this.code).value
        }
      } catch (e) {
        codeHtml = this.escapeHtml(this.code)
      }

      const styles = `
        <style>
        pre code.hljs {
          display: block;
          overflow-x: auto;
          padding: 1em
        }
        code.hljs {
          padding: 3px 5px
        }
        .hljs {
          color: rgba(0, 0, 0, 0.8);
          background: rgba(140, 147, 176, 0.1);
          border-bottom-left-radius: 8px;
          border-bottom-right-radius: 8px;
        }
        .hljs-doctag,
        .hljs-keyword,
        .hljs-meta .hljs-keyword,
        .hljs-template-tag,
        .hljs-template-variable,
        .hljs-type,
        .hljs-variable.language_ {
          color: #ff7b72;
        }
        .hljs-title,
        .hljs-title.class_,
        .hljs-title.class_.inherited__,
        .hljs-title.function_ {
          color: #d2a8ff;
        }
        .hljs-attr,
        .hljs-attribute,
        .hljs-literal,
        .hljs-meta,
        .hljs-number,
        .hljs-operator,
        .hljs-variable,
        .hljs-selector-attr,
        .hljs-selector-class,
        .hljs-selector-id {
          color: #79c0ff;
        }
        .hljs-regexp,
        .hljs-string,
        .hljs-meta .hljs-string {
          color: #a5d6ff;
        }
        .hljs-built_in,
        .hljs-symbol {
          color: #ffa657;
        }
        .hljs-comment,
        .hljs-code,
        .hljs-formula {
          color: #8b949e;
        }
        .hljs-name,
        .hljs-quote,
        .hljs-selector-tag,
        .hljs-selector-pseudo {
          color: #7ee787;
        }
        </style>
      `
      return styles + `<pre><code class="hljs">${codeHtml}</code></pre>`
    },
  },
  
  escapeHtml(unsafe) {
    return unsafe
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;')
  },
  
  handleCopy() {
    clipboard.set({
      text: this.code,
      success: () => {
        prompt.showToast({
          message: '已复制',
        })
      },
    })
  },
}
</script>

<style>
.code-block-container {
  width: 367px;
  flex-direction: column;
  align-items: center;
}

.code-header {
  width: 352px;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  background-color: rgba(140, 147, 176, 0.3);
  padding: 8px 12px;
  border-top-left-radius: 8px;
  border-top-right-radius: 8px;
  margin-bottom: -8px;
}

.language-label {
  color: #000000;
  font-size: 14px;
  line-height: 20px;
  font-family: MiSans VF;
  font-weight: bold;
}

.copy-button {
  padding: 4px 8px;
}

.copy-text {
  color: #3482ff;
  font-size: 14px;
  line-height: 20px;
  font-family: MiSans VF;
}

.copy-button:active .copy-text {
  color: #2980b9;
}
</style>
